ANTHROPIC_API_KEY=

# Filled in by `npm run setup` (src/setup.ts)
ENVIRONMENT_ID=
ENGINEER_AGENT_ID=
TESTER_AGENT_ID=
JIRA_MANAGER_AGENT_ID=
ORCHESTRATOR_AGENT_ID=

# Filled in by `npm run setup:vault` (src/setup-vault.ts) — requires OAuth
# tokens for the GitHub and Jira MCP servers first
VAULT_ID=
GITHUB_MCP_ACCESS_TOKEN=
JIRA_MCP_ACCESS_TOKEN=

# Used by src/build.ts when mounting the repo the Engineer works in
GITHUB_REPO_URL=https://github.com/your-org/your-repo
GITHUB_TOKEN=
